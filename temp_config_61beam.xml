        <reffunc_add>/home/shy/AIR/小长/GMTI_Data/Mission068/RefFun_Br50MHz_Tr38us_Len4096.dat</reffunc_add>
        <isSeparated>separate</isSeparated>
        <INFO_Type>1</INFO_Type>
        <GMTI_data_new>/home/shy/AIR/小长/GMTI_Data/Mission068/newdata/gmti_data_13.dat</GMTI_data_new>
        <pipe_root_path>/home/raco</pipe_root_path>
        <estimate_error_angle>0</estimate_error_angle>
        <wavepos_parallel>1</wavepos_parallel>
        <enable_dbs_fusion>1</enable_dbs_fusion>
        <iq_compose>I+jQ</iq_compose>
        <isPC>0</isPC>
        <hasRefFunc>0</hasRefFunc>

        <!-- 新协议：每个 PRT 为 256 字节头 + 11820 点双通道复数 float32。 -->
        <info_len>256</info_len>
        <pulse_len>11820</pulse_len>
        <rg_len>4096</rg_len>
        <!-- 11820 点输入尾部补零至 12288，IFFT 后从 0-based 3864 截取 4096 点。 -->
        <range_fft_len>12288</range_fft_len>
        <range_crop_start>3864</range_crop_start>
        <range_compress_len>4096</range_compress_len>

        <!-- 每个波位存储 130 个 PRT；从偏移 1 开始读取中间 128 个用于方位 FFT。 -->
        <pulse_num>130</pulse_num>
        <read_pulse_num>128</read_pulse_num>
        <read_pulse_offset>1</read_pulse_offset>
        <pulse_dec>1</pulse_dec>

        <fc>17</fc>
        <Br>50</Br>
        <!-- 4096 点原始采样经 3 倍 FFT 插值后，等效距离采样率为 225 MHz。 -->
        <fs>225</fs>
        <Tr>38</Tr>
        <PRF>1300</PRF>
        <Rmin>13950</Rmin>
        <d_chan>0.17</d_chan>
        <ref_lon>117</ref_lon>
        <ref_H>20</ref_H>
        <pf>1e-6</pf>
        <secBias>18</secBias>

        <!-- 造数文件已经是完整的 61 波位目标文件，不再跳过源脉冲。 -->
        <skip_pulses>0</skip_pulses>
        <wavepos_use_roi>false</wavepos_use_roi>
        <roi_lat1>40.45121057</roi_lat1>
        <roi_lng1>116.98377429</roi_lng1>
        <roi_Ry1>400</roi_Ry1>
        <roi_Rx1>400</roi_Rx1>

        <wavepos_st>1</wavepos_st>
        <wavepos_ed>61</wavepos_ed>
