{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (macOS • LLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/GMTI_core",
      "args": [
        "${input:xmlPath}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "externalConsole": false,
      "preLaunchTask": "CMake: build (Debug)"
    },
    {
      "name": "Debug (Linux • GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/GMTI_core",
      "args": [
        "${input:xmlPath}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "externalConsole": false,
      "preLaunchTask": "CMake: build (Debug)"
    },
    {
      "name": "Debug (Windows • MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
        "${input:xmlPath}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build (Debug)"
    }
  ],
  "inputs": [
    {
      "id": "xmlPath",
      "type": "promptString",
      "description": "Path to scan_GMTI_parameter.xml",
      "default": "${workspaceFolder}/scan_GMTI_parameter.xml"
    }
  ],
  "setupCommands": [
    {
      "text": "settings set target.max-children-count 50"
    },
    {
      "text": "settings set target.max-string-summary-length 128"
    },
    {
      "text": "settings set target.max-summary-length 256"
    }
  ]
}