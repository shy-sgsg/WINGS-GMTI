{
  "configurations": [
    {
      "name": "macOS",
      "macFrameworkPath": [
        "/System/Library/Frameworks",
        "/Library/Frameworks"
      ],
      "includePath": [
        "${workspaceFolder}/include",
        "/opt/homebrew/include",                         // or /usr/local/include
        "/opt/homebrew/opt/fftw/include",
        "/opt/homebrew/opt/proj/include",
        "/opt/homebrew/opt/tinyxml2/include",
        "/opt/homebrew/opt/libomp/include"              // 若用 OpenMP
      ],
      "defines": [
        "USE_OPENMP",                                   // 若启用 OpenMP
        // "USE_ACCELERATE",                            // 如你写了 Accelerate 后端
        // "USE_MKL"                                    // mac 上一般不用 MKL（Apple Silicon 无原生）
        "_USE_MATH_DEFINES"
      ],
      "compilerPath": "/usr/bin/clang++",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "macos-clang-arm64",          // Apple Silicon；Intel 改为 macos-clang-x64
      "browse": {
        "path": [
          "${workspaceFolder}",
          "/opt/homebrew/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ],
  "version": 4
}
